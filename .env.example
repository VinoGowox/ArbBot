# Pair format follows unified notation BASE/QUOTE, example BTC/USDT
SYMBOLS=BTC/USDT,ETH/USDT,SOL/USDT

# Select exchanges to scan (comma-separated)
ENABLED_EXCHANGES=okx,kucoin

# Trading fees as fraction, 0.001 = 0.1%
DEFAULT_TAKER_FEE_RATE=0.001

# Minimum net spread percentage to be considered interesting
MIN_NET_SPREAD_PCT=0.2

# Minimum estimated net profit in quote currency per scan candidate
MIN_NET_PROFIT_QUOTE=0

# Notional size used to estimate profit in quote currency
TRADE_SIZE_QUOTE=1000

# Slippage buffer in basis points applied to both legs
SLIPPAGE_BPS=2

# Append every scan candidate to CSV for offline analysis
SNAPSHOT_CSV_PATH=data/arbitrage_opportunities.csv

# Telegram alert (optional)
TELEGRAM_ENABLED=false
# TELEGRAM_BOT_TOKEN=123456:ABCDEF
# TELEGRAM_CHAT_ID=123456789

# Exchange taker fee map, default 0.1% if not listed in code
# BINANCE_SPOT_FEE=0.001
# BYBIT_SPOT_FEE=0.001
# OKX_SPOT_FEE=0.001
# KUCOIN_SPOT_FEE=0.001
